{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A shopping product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "stock": { "type": "integer" }
      },
      "required": ["id", "name", "price", "category", "image"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "CartItem": {
      "title": "CartItem",
      "description": "An item in a user's cart",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "integer" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "stock": { "type": "integer" }
      },
      "required": ["id", "name", "price", "quantity"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "CartItem" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered", "cancelled"] },
        "paymentMethod": { "type": "string", "enum": ["bKash", "Nagad", "Cash on Delivery"] },
        "customerInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          },
          "required": ["name", "phone", "address"]
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "items", "total", "status", "paymentMethod", "customerInfo", "createdAt"]
    },
    "PaymentSettings": {
      "title": "PaymentSettings",
      "description": "Payment configuration for bKash and Nagad",
      "type": "object",
      "properties": {
        "bkashNumber": { "type": "string" },
        "nagadNumber": { "type": "string" }
      }
    },
    "SiteSettings": {
      "title": "SiteSettings",
      "description": "Global website content settings",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroImages": { "type": "array", "items": { "type": "string" } },
        "featuredTitle": { "type": "string" },
        "featuredSubtitle": { "type": "string" },
        "newsletterTitle": { "type": "string" },
        "newsletterSubtitle": { "type": "string" },
        "newsletterDescription": { "type": "string" },
        "footerText": { "type": "string" },
        "aboutTitle": { "type": "string" },
        "aboutText": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" },
        "contactAddress": { "type": "string" },
        "banners": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "image": { "type": "string" },
              "title": { "type": "string" },
              "subtitle": { "type": "string" },
              "link": { "type": "string" }
            }
          }
        }
      },
      "required": ["heroTitle", "heroSubtitle", "heroImages", "featuredTitle", "featuredSubtitle", "newsletterTitle", "newsletterSubtitle", "newsletterDescription", "footerText"]
    },
    "Review": {
      "title": "Review",
      "description": "A product review",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all products"
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/settings/{docId}": {
      "schema": "SiteSettings",
      "description": "Global site configuration and content"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/users/{userId}/cart/{itemId}": {
      "schema": "CartItem",
      "description": "User's shopping cart items"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    }
  }
}
